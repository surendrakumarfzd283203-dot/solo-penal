<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0d0d0d">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SOLO PENAL LOGIN"
        android:textColor="#ff9d00"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/etUserKey"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Access Key (User ID)"
        android:textColor="#FFFFFF"
        android:textColorHint="#888"
        android:backgroundTint="#ff9d00"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Password"
        android:textColor="#FFFFFF"
        android:textColorHint="#888"
        android:backgroundTint="#ff9d00"
        android:inputType="textPassword"
        android:padding="12dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnStartPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VERIFY &amp; START"
        android:backgroundTint="#ff9d00"
        android:textColor="#000"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textColor="#ff0055"
        android:text="" />

</LinearLayout>
